#!/usr/bin/env bash
set -euo pipefail

mind="${MIND_BIN:?MIND_BIN must point at the mind binary}"
workspace="$(mktemp -d)"
socket="$workspace/mind.sock"
store="$workspace/mind.redb"

"$mind" daemon --socket "$socket" --store "$store" >"$workspace/daemon.log" 2>&1 &
daemon="$!"
trap 'kill "$daemon" 2>/dev/null || true' EXIT

for _ in $(seq 1 100); do
  [[ -S "$socket" ]] && break
  sleep 0.05
done
test -S "$socket"

"$mind" \
  --socket "$socket" \
  --actor operator \
  '(Opening Task High "Daemon owns state" "sent through signal frames")' \
  >"$workspace/opening.out"

"$mind" \
  --socket "$socket" \
  --actor operator \
  '(Query (Open) 10)' \
  >"$workspace/query.out"

grep -Fq '(OpeningReceipt' "$workspace/opening.out"
grep -Fq '"Daemon owns state"' "$workspace/query.out"
