#!/usr/bin/env bash
set -euo pipefail

mind="${MIND_BIN:?MIND_BIN must point at the mind binary}"
mind_daemon="${MIND_DAEMON_BIN:?MIND_DAEMON_BIN must point at the mind-daemon binary}"
configuration_writer="${MIND_CONFIGURATION_WRITER_BIN:?MIND_CONFIGURATION_WRITER_BIN must point at the mind-write-configuration binary}"
workspace="$(mktemp -d)"
socket="$workspace/mind.sock"
meta_socket="$workspace/mind.meta.sock"
store="$workspace/mind.redb"
configuration="$workspace/mind.rkyv"

"$configuration_writer" \
  "(ConfigurationWriteRequest $socket $meta_socket $store $configuration)" \
  >"$workspace/configuration.out"

"$mind_daemon" "$configuration" >"$workspace/daemon.log" 2>&1 &
daemon="$!"
trap 'kill "$daemon" 2>/dev/null || true' EXIT

for _ in $(seq 1 100); do
  [[ -S "$socket" ]] && break
  sleep 0.05
done
test -S "$socket"

MIND_SOCKET="$socket" \
MIND_ACTOR=operator \
"$mind" \
  '(Opening Task High [One record] [created by the one-record check])' \
  >"$workspace/reply.out"

test "$(wc -l <"$workspace/reply.out")" -eq 1
grep -Fq '(OpeningReceipt' "$workspace/reply.out"
grep -Fq '[One record]' "$workspace/reply.out"

set +e
MIND_SOCKET="$socket" \
MIND_ACTOR=operator \
"$mind" \
  '(Query (Open) 10)' \
  '(Query (Open) 10)' \
  >"$workspace/two-records.out" \
  2>"$workspace/two-records.err"
status="$?"
set -e

if [[ "$status" -eq 0 ]]; then
  echo "mind accepted more than one NOTA request record" >&2
  exit 1
fi

grep -Fq "expected exactly one component argument, received 2" "$workspace/two-records.err"
